# yakyoke configuration -- copy to .env and edit.

# --- LLM provider ---
# Pick ONE default. Override per-task at submit time with `--model`.

# Local Ollama (no API key needed):
YAKYOKE_DEFAULT_MODEL=ollama/gemma3:27b
# OLLAMA_API_BASE=http://localhost:11434

# Anthropic Claude:
# YAKYOKE_DEFAULT_MODEL=claude-opus-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI:
# YAKYOKE_DEFAULT_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- Daemon settings ---
YAKYOKE_HOST=127.0.0.1
YAKYOKE_PORT=8765

# Where the SQLite db and per-task workspaces live.
YAKYOKE_DATA_DIR=~/.yakyoke

# Cap on agent loop iterations per task.
YAKYOKE_MAX_STEPS=12

# --- Auth ---
# Bearer token for the HTTP API. If set, every task route requires
#   Authorization: Bearer <token>
# /health stays open so liveness checks work without credentials.
# Leave blank to disable auth (safe ONLY for localhost on a single-user box).
# Generate a fresh value with: yakyoke token
# YAKYOKE_API_TOKEN=replace-with-output-of-yakyoke-token
